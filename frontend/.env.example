# ──────────────────────────────────────────────────────────────────────────────
# MUSB RESEARCH FRONTEND - ENVIRONMENT VARIABLES EXAMPLE
# ──────────────────────────────────────────────────────────────────────────────

# --- NextAuth ---
# Change this to your production URL
NEXTAUTH_URL=http://localhost:3000
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=changeme_at_least_32_chars

# --- Database (Prisma) ---
# Format: mongodb+srv://USER:PASS@HOST/DB
DATABASE_URL="mongodb://localhost:27017/musb_research"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- reCAPTCHA (v2) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# --- Backend API ---
# URL of the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- App URL ---
# Used for absolute links in emails/metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- SMTP Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
